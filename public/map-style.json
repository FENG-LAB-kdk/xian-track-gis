{
  "version": 8,
  "name": "osm-light",
  "sources": {
    "osm_source": {
          "type": "raster",
          "tiles": [
            "https://a.tile.openstreetmap.fr/hot/{z}/{x}/{y}.png"
          ],
          "tileSize": 256,
          "attribution": "&copy; <a href=\"https://www.openstreetmap.org/copyright\">OpenStreetMap</a> contributors"
        }
      },
      "layers": [
        {
          "id": "osm-layer",
          "type": "raster",
          "source": "osm_source",
      "minzoom": 0,
      "maxzoom": 19
    }
  ]
}
